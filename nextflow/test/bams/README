zcat ../VCF/DNA-001.GRCh37.FINAL.vcf.gz | awk '! /\#/' | awk '{if(length($4) > length($5)) print $1"\t"($2-1)"\t"($2+length($4)-1); else print $1"\t"($2-1)"\t"($2+length($5)-1)}' > regions.GRCh37.bed
zcat ../VCF/DNA-001.GRCh38.FINAL.vcf.gz | awk '! /\#/' | awk '{if(length($4) > length($5)) print $1"\t"($2-1)"\t"($2+length($4)-1); else print $1"\t"($2-1)"\t"($2+length($5)-1)}' > regions.GRCh38.bed

zcat ../VCF/DNA-001.GRCh37.FINAL.vcf.gz | awk '! /\#/' | awk '{if(length($4) > length($5)) print $1"\t"($2-1)"\t"($2+length($4)-1); else print $1"\t"($2-5)"\t"($2+length($5)+4)}' > regions.GRCh37.bed
zcat ../VCF/DNA-001.GRCh38.FINAL.vcf.gz | awk '! /\#/' | awk '{if(length($4) > length($5)) print $1"\t"($2-1)"\t"($2+length($4)-1); else print $1"\t"($2-5)"\t"($2+length($5)+4)}' > regions.GRCh38.bed

