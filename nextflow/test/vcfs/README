ml HTSlib/1.16-GCCcore-11.3.0
ml BCFtools
for i in {1..6}
do
	echo "DNA-00${i}.GRCh37" > file.txt
	bcftools reheader -s file.txt -o HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.reader.vcf HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.vcf
	bcftools sort HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.reader.vcf -o HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.reader.vcf 
	bgzip -c HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.reader.vcf > "DNA-00${i}.GRCh37.FINAL.vcf.gz"
	tabix -p vcf "DNA-00${i}.GRCh37.FINAL.vcf.gz"
	
	echo "DNA-00${i}.GRCh38" > file.txt
	bcftools reheader -s file.txt -o HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.vcf
	bcftools sort HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf -o HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf
	bgzip -c HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf > "DNA-00${i}.GRCh38.FINAL.vcf.gz"
	tabix -p vcf "DNA-00${i}.GRCh38.FINAL.vcf.gz"
done

for i in {7..9}
do
        echo "RNA-00${i}.GRCh37" > file.txt
        bcftools reheader -s file.txt -o HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.reader.vcf HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.vcf
        bgzip -c HG002_GRCh37_1_22_v4.1_draft_benchmark.head1k.reader.vcf > "RNA-00${i}.GRCh37.FINAL.vcf.gz"
        tabix -p vcf "RNA-00${i}.GRCh37.FINAL.vcf.gz"
        
        echo "RNA-00${i}.GRCh38" > file.txt
        bcftools reheader -s file.txt -o HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.vcf
        bcftools sort HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf -o HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf
	bgzip -c HG002_GRCh38_1_22_v4.1_draft_benchmark.head1k.reader.vcf > "RNA-00${i}.GRCh38.FINAL.vcf.gz"
        tabix -p vcf "RNA-00${i}.GRCh38.FINAL.vcf.gz"
done

	# NA12878.GRCh38 and NA12878.GRCh37
	echo "NA12878.GRCh38" > file.txt
	bcftools reheader -s file.txt -o NA12878.GRCh38.vcf 105856-047-HG001.hard-filtered.vcf.gz
	bcftools sort NA12878.GRCh38.vcf -o NA12878.GRCh38.sorted.vcf
	bgzip -c NA12878.GRCh38.sorted.vcf > "NA12878.GRCh38.sorted.vcf.gz"
	bedtools intersect -a NA12878.GRCh38.sorted.vcf.gz -b /apps/data/UMCG/concordanceCheckSnps_GRCh38.bed > NA12878.GRCh38.sorted.intersect.txt
	grep '#' NA12878.GRCh38.sorted.vcf > NA12878.GRCh38.sorted.header
	cat NA12878.GRCh38.sorted.header NA12878.GRCh38.sorted.intersect.txt > NA12878.GRCh38.sorted.vcf
	bgzip -c NA12878.GRCh38.sorted.vcf > "NA12878.GRCh38.sorted.vcf.gz"
	tabix -p vcf "NA12878.GRCh38.sorted.vcf.gz"

